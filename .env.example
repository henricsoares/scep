# Local development template.
# Create a .env file from this template before running Docker Compose.
APP_NAME=SCEP Backend API
APP_ENV=local
APP_VERSION=0.1.0
DATABASE_URL=postgresql+psycopg://scep:scep@localhost:5432/scep
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-in-local-development-only-not-for-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
BOOTSTRAP_ADMIN_EMAIL=admin@scep.local
BOOTSTRAP_ADMIN_PASSWORD=LocalAdmin123!
BOOTSTRAP_ADMIN_DISPLAY_NAME=SCEP Administrator
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SDK_DISABLED=false
DATASET_EXPORT_MAX_WINDOW_DAYS=366
DATASET_EXPORT_MAX_ROWS=1000000
DATASET_EXPORT_MAX_ARTIFACT_SIZE_BYTES=1073741824
DATASET_EXPORT_MAX_CONCURRENT_JOBS=2
DATASET_EXPORT_MAX_QUEUED_JOBS=100
DATASET_EXPORT_RETENTION_DAYS=30
DATASET_EXPORT_ENABLED_FORMATS=CSV,PARQUET
DATASET_EXPORT_STORAGE_PATH=/var/lib/scep/dataset-exports
DATASET_EXPORT_PROCESSING_TIMEOUT_SECONDS=900
DATASET_EXPORT_ABANDONED_TIMEOUT_SECONDS=1800
DATASET_EXPORT_PSEUDONYMIZATION_SECRET=change-me-dataset-export-local
DATASET_EXPORT_PSEUDONYMIZATION_KEY_VERSION=v1
SOURCE_REVISION=
